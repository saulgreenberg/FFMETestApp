<Window x:Class="FFMETestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ffme="clr-namespace:Unosquare.FFME;assembly=ffme.win"
        mc:Ignorable="d"
        Title="FFME Test Application - Airspace &amp; Overlay Testing" Height="700" Width="1400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Control Panel - WrapPanel so controls can reflow on narrow windows -->
        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="5,4">

            <!-- File and Transport Controls -->
            <Button x:Name="ButtonOpenFile" Content="Open Video" Width="90" Height="28" Margin="3,3,4,3"
                    VerticalAlignment="Center" Click="ButtonOpenFile_Click"
                    ToolTip="Standard file dialog that opens in the included Videos folder and lets you select a video&#10;Illustrates how to open and load a video"/>
            <Button x:Name="ButtonOpenByThumbnail" Content="Open by Video Thumbnails" Width="155" Height="28" Margin="3,3,6,3"
                    VerticalAlignment="Center" Click="ButtonOpenByThumbnail_Click"
                    ToolTip="Displays a dialog box showing thumbnails of all videos in the video folder (1 second in).&#10;Illustrates how to create video thumbnails"/>
            <Button x:Name="ButtonPlayPause" Width="32" Height="28" Margin="3,3,1,3"
                    VerticalAlignment="Center" Click="PlayPauseButton_Click"
                    ToolTip="Toggles video playing/pausing&#10;Illustrates how to play/pause a video">
                <TextBlock x:Name="PlayPauseIcon" Text="▶" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
            <Button x:Name="ButtonStop" Width="32" Height="28" Margin="1,3,6,3"
                    VerticalAlignment="Center" Click="StopButton_Click"
                    ToolTip="Stops playing&#10;Illustrates stopping a video and resetting it back to the beginning">
                <TextBlock Text="■" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <!-- Volume -->
            <TextBlock Text="Volume:" VerticalAlignment="Center" Margin="0,0,0,0"/>
            <Slider x:Name="SliderVolume" Width="75" Margin="0,0,8,0"
                    Minimum="0" Maximum="1" Value="0.5" VerticalAlignment="Center"
                    ValueChanged="VolumeSlider_ValueChanged"
                    ToolTip="Adjust the volume&#10;Illustrates dynamically adjusting the video volume"/>

            <!-- Position Scrub -->
            <TextBlock Text="Position:" VerticalAlignment="Center"/>
            <Slider x:Name="PositionSlider" Width="160" Margin="0,0,8,0"
                    Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center"
                    ValueChanged="PositionSlider_ValueChanged"
                    PreviewMouseDown="PositionSlider_PreviewMouseDown"
                    PreviewMouseUp="PositionSlider_PreviewMouseUp"
                    ToolTip="Allows the video to be scrubbed manually during play or pause&#10;Illustrates scrubbing, which is somewhat more complex than you think. Note that ScrubbingEnabled=&quot;False&quot; must be set to avoid unwanted effects"/>

            <!-- Overlay / Zoom / Repeat / Dual-buffer checkboxes -->
            <CheckBox x:Name="ShowOverlaysCheckBox" Content="Overlays" Margin="3,0,6,0"
                      VerticalAlignment="Center" IsChecked="True"
                      Checked="ShowOverlaysCheckBox_Changed" Unchecked="ShowOverlaysCheckBox_Changed"
                      ToolTip="Shows frame number and position at the top, and a progress bar showing its position at the bottom&#10;Illustrates how a video can be overlayed by other WPF elements in a canvas"/>
            <CheckBox x:Name="EnableZoomCheckBox" Content="Zoom" Margin="0,0,6,0"
                      VerticalAlignment="Center" IsChecked="True"
                      Checked="EnableZoomCheckBox_Changed" Unchecked="EnableZoomCheckBox_Changed"
                      ToolTip="Allows zooming in and out of the video&#10;Illustrates zooming, and how the overlays can be clamped to corners of the video&#10;When enabled: scroll wheel to zoom, drag to pan, double-click to reset"/>
            <CheckBox x:Name="AutoRepeatCheckBox" Content="Repeat" Margin="0,0,6,0"
                      VerticalAlignment="Center" IsChecked="True"
                      ToolTip="Auto-repeat the video when it reaches its end&#10;Illustrates how to reset the video to its beginning and replay it when it reaches its end"/>
            <CheckBox x:Name="UseDualBufferCheckBox" Content="Dual-buffer" Margin="0,0,6,0"
                      VerticalAlignment="Center" IsChecked="True"
                      ToolTip="Toggle use of a dual buffer to show smooth video transitions when opening/switching to a new video&#10;Illustrates how we use two video players to avoid the visually annoying 'black screen' that occurs when a video is opened or switched"/>
            <CheckBox x:Name="HardwareAccelCheckBox" Content="Hardware accelerated" Margin="0,0,6,0"
                      VerticalAlignment="Center" IsChecked="False"
                      Checked="HardwareAccelCheckBox_Changed" Unchecked="HardwareAccelCheckBox_Changed"
                      ToolTip="Try to use hardware acceleration."/>
            <CheckBox x:Name="UseDirectSoundCheckBox" Content="Use direct sound" Margin="0,0,6,0"
                      VerticalAlignment="Center" IsChecked="True"
                      Checked="UseDirectSoundCheckBox_Changed" Unchecked="UseDirectSoundCheckBox_Changed"
                      ToolTip="Indicates whether to use DirectSound or the legacy WinMM audio engine.&#10;Useful for testing a previous bug in DirectSound that caused crashes when switching between videos"/>

            <!-- Speed -->
            <GroupBox Header="Speed" Margin="2,0,2,0">
                <StackPanel Orientation="Horizontal" Margin="4,1" VerticalAlignment="Center">
                    <RadioButton x:Name="Speed05" Content=".5x" GroupName="Speed" Margin="2,0"
                         VerticalAlignment="Center" Checked="SpeedRadioButton_Checked"
                         ToolTip="Change the video speed&#10;Illustrates how to change the speed of the running video"/>
                    <RadioButton x:Name="Speed10" Content="1x" GroupName="Speed" IsChecked="True" Margin="2,0"
                         VerticalAlignment="Center" Checked="SpeedRadioButton_Checked"
                         ToolTip="Change the video speed&#10;Illustrates how to change the speed of the running video"/>
                    <RadioButton x:Name="Speed20" Content="2x" GroupName="Speed" Margin="2,0,6,0"
                         VerticalAlignment="Center" Checked="SpeedRadioButton_Checked"
                         ToolTip="Change the video speed&#10;Illustrates how to change the speed of the running video"/>
                </StackPanel>
            </GroupBox>

            <!-- Auto Switch GroupBox -->
            <GroupBox Margin="3,2">
                <GroupBox.Header>
                    <CheckBox x:Name="AutoSwitchCheckBox" Content="Switch videos automatically"
                              VerticalAlignment="Center"
                              Checked="AutoSwitchCheckBox_Changed" Unchecked="AutoSwitchCheckBox_Changed"
                              ToolTip="Closes the current video and opens another random video after the interval set in the slider&#10;Illustrates time constraints in opening/closing videos rapidly, helpful for certain UI situations"/>
                </GroupBox.Header>
                <StackPanel Orientation="Horizontal" Margin="4,1" VerticalAlignment="Center">
                    <TextBlock Text="Interval:" VerticalAlignment="Center"/>
                    <Slider x:Name="AutoSwitchTime" Width="90" Margin="0,0,4,0"
                            Minimum="0.001" Maximum="5" Value="2" VerticalAlignment="Center"
                            TickFrequency="0.5" IsSnapToTickEnabled="False"
                            IsEnabled="{Binding IsChecked, ElementName=AutoSwitchCheckBox}"
                            ValueChanged="SliderAutoSwitchTime_ValueChanged"/>
                    <TextBlock x:Name="SliderAutoSwitchTimeLabel" VerticalAlignment="Center" Text="2.00s"/>
                    <Button x:Name="ButtonNext" Content="Next" Width="45" Height="22" Margin="6,0,0,0"
                            VerticalAlignment="Center" Click="ButtonNext_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=AutoSwitchCheckBox}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </GroupBox>

        </WrapPanel>

        <!-- Main Video Area with Overlays -->
        <Grid x:Name="GridVideoPanel" Grid.Row="1" Margin="10" Background="Black" Focusable="True" ClipToBounds="True">
            <Rectangle x:Name="VideoBackground" Fill="DarkSlateGray" Opacity="0.8"/>

            <!-- Primary Video Player (active) Note that ScrubbingEnabled must be false for smooth scrubbing .01-->
            <!-- To silence a minor designer warning: Extract the two MediaElement controls into a UserControl — then put
                 d:IsDesignTimeCreatable="False" on that UserControl. This works but requires refactoring and
                 not worth the bother.
            -->
            <ffme:MediaElement x:Name="VideoPlayer"
                             LoadedBehavior="Manual"
                             UnloadedBehavior="Manual"
                             ScrubbingEnabled="False"
                             Volume="0.5"
                             Stretch="Uniform"
                             MediaOpened="VideoPlayer_MediaOpened"
                             PositionChanged="VideoPlayer_PositionChanged"
                             MediaEnded="VideoPlayer_MediaEnded"/>

            <!-- Back-buffer Video Player: hidden and muted while preloading next video -->
            <ffme:MediaElement x:Name="VideoPlayer2"
                             LoadedBehavior="Manual"
                             UnloadedBehavior="Manual"
                             ScrubbingEnabled="False"
                             Volume="0"
                             Stretch="Uniform"
                             Visibility="Hidden"
                             MediaOpened="VideoPlayer_MediaOpened"
                             PositionChanged="VideoPlayer_PositionChanged"
                             MediaEnded="VideoPlayer_MediaEnded"/>

            <!-- Overlay Canvas (on top of both video players) -->
            <Canvas x:Name="OverlayCanvas" Background="Transparent" IsHitTestVisible="False">

                <!-- Position progress bar: width grows left→right as percentage of video duration -->
                <Rectangle x:Name="PositionBar"
                           Canvas.Left="0" Canvas.Top="0"
                           Width="0" Height="50"
                           Fill="DodgerBlue" Opacity="0.45"/>

                <Rectangle x:Name="PositionIndicator"
                           Canvas.Left="0" Canvas.Top="0"
                           Width="10" Height="50"
                           Stroke="Yellow" StrokeThickness="2"
                           Fill="Transparent"/>

                <TextBlock x:Name="FrameNumberText"
                          Canvas.Left="10" Canvas.Top="10"
                          Text="Frame 001"
                          Foreground="White"
                          FontSize="16" FontWeight="Bold"
                          Background="Black" Opacity="0.8" Padding="5"/>

                <TextBlock x:Name="TimestampText"
                          Canvas.Left="10" Canvas.Top="42"
                          Text="2024-01-15 10:30:45"
                          Foreground="Lime"
                          FontSize="14"
                          Background="Black" Opacity="0.7" Padding="3"/>


                <TextBlock x:Name="PositionLabel"
                          Canvas.Left="350" Canvas.Top="180"
                          Text="0.0s"
                          Foreground="Yellow"
                          FontSize="12" FontWeight="Bold"
                          Background="Black" Opacity="0.8" Padding="2"/>
            </Canvas>
        </Grid>

        <!-- Gesture / Keyboard Reference Bar -->
        <Grid Grid.Row="2" Background="#F0F0F0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Margin="10,4" TextWrapping="Wrap"
                       Text="&#x1F5B1; Scroll wheel: Zoom the video in and out. Also illustrates how the overlays are clamped to corners of the video."/>
            <TextBlock Grid.Column="1" Margin="10,4" TextWrapping="Wrap"
                       Text="&#x1F5B1; Click and drag: Pan the video, which can be in a zoomed state. Also illustrates translation and how the overlays are clamped to corners of the video."/>
            <TextBlock Grid.Column="2" Margin="10,4" TextWrapping="Wrap"
                       Text="&#x1F5B1; Double-click: Set zoom and translation to its defaults."/>
            <TextBlock Grid.Column="3" Margin="10,4" TextWrapping="Wrap"
                       Text="&#x2190; &#x2192; Arrow keys: Go to the next/previous frame. Illustrates frame by frame navigation."/>
        </Grid>

        <!-- Status Panel -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="10" Background="LightGray">
            <TextBlock x:Name="StatusText" Text="Ready" Margin="10" VerticalAlignment="Center"/>
            <TextBlock x:Name="PositionText" Text="00:00:00 / 00:00:00" Margin="20,10" VerticalAlignment="Center"
                       ToolTip="Illustrates how to get video information, such as its position, resolution, and frames per second."/>
            <TextBlock x:Name="ResolutionText" Text="Resolution: N/A" Margin="20,10" VerticalAlignment="Center"
                       ToolTip="Illustrates how to get video information, such as its position, resolution, and frames per second."/>
            <TextBlock x:Name="FrameRateText" Text="FPS: N/A" Margin="20,10" VerticalAlignment="Center"
                       ToolTip="Illustrates how to get video information, such as its position, resolution, and frames per second."/>
            <TextBlock x:Name="HwAccelText" Text="Decode: Software" Margin="20,10" VerticalAlignment="Center"
                       ToolTip="Illustrates how to get video information, such as its position, resolution, and frames per second."/>
            <TextBlock x:Name="AudioEngineText" Text="Audio: N/A | WinMM" Margin="20,10" VerticalAlignment="Center"
                       ToolTip="Audio codec of the loaded video and the audio output engine in use (DirectSound or WinMM legacy)."/>
            <TextBlock x:Name="FfmeVersionText" Text="FFME: ..." Margin="20,10" VerticalAlignment="Center"
                       ToolTip="Version of the zgabi.FFME.Windows assembly loaded at runtime."/>
        </StackPanel>
    </Grid>
</Window>
