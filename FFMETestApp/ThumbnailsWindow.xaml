<Window x:Class="FFMETestApp.ThumbnailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Thumbnails" Height="700" Width="1050"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText" Grid.Row="0"
                   Margin="10,6" FontSize="13"
                   Text="Loading thumbnails…"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="ThumbnailsPanel" Margin="6" Orientation="Horizontal"/>
        </ScrollViewer>
    </Grid>
</Window>
